---
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}
---

<footer class="not-prose border-t border-[#4e453b] bg-[#161b2b] text-[#dee1f7]">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-12 md:py-20">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <a
          href={getHomePermalink()}
          class="inline-block font-bold uppercase tracking-[0.15em] text-[#cda777] text-xl"
          style="font-family:'Noto Serif',serif;"
        >
          THE MATCH BUREAU
        </a>
        <p
          class="mt-5 uppercase tracking-[0.25em] text-[0.7rem] text-[#eac290]"
          style="font-family:'Newsreader',serif;"
        >
          PRIVATE MATCHMAKING · NEW ZEALAND
        </p>
        <div class="mt-10 h-px w-24 bg-[#4e453b]"></div>
      </div>

      <nav class="lg:col-span-3" aria-label="City links">
        <h2
          class="mb-6 uppercase tracking-[0.25em] text-[0.7rem] text-[#eac290]"
          style="font-family:'Newsreader',serif;"
        >
          Cities
        </h2>
        <ul class="space-y-4">
          <li><a class="footer-link" href="/cities/auckland">Auckland</a></li>
          <li><a class="footer-link" href="/cities/wellington">Wellington</a></li>
          <li><a class="footer-link" href="/cities/christchurch">Christchurch</a></li>
          <li><a class="footer-link" href="/cities/queenstown">Queenstown</a></li>
        </ul>
      </nav>

      <nav class="lg:col-span-2" aria-label="Bureau links">
        <h2
          class="mb-6 uppercase tracking-[0.25em] text-[0.7rem] text-[#eac290]"
          style="font-family:'Newsreader',serif;"
        >
          Bureau
        </h2>
        <ul class="space-y-4">
          <li><a class="footer-link" href="/membership">Membership</a></li>
          <li><a class="footer-link" href="/process">The Process</a></li>
          <li><a class="footer-link" href="/about">About</a></li>
          <li><a class="footer-link" href="/blog">Blog</a></li>
          <li><a class="footer-link" href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="flex items-start lg:col-span-2 lg:justify-end">
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-[#cda777] px-8 py-4 text-center uppercase tracking-[0.25em] text-[0.75rem] font-bold text-[#573c15] transition-colors duration-300 hover:bg-[#eac290]"
          style="font-family:'Noto Serif',serif;"
        >
          Apply Now
        </a>
      </div>
    </div>

    <div
      class="mt-16 flex flex-col gap-5 border-t border-[#4e453b] pt-8 md:flex-row md:items-center md:justify-between"
    >
      <p
        class="uppercase tracking-[0.2em] text-[0.65rem] text-[#d2c4b7]/70"
        style="font-family:'Newsreader',serif;"
      >
        © 2025 The Match Bureau. All rights reserved.
      </p>
      <div class="flex gap-8">
        <a class="footer-legal-link" href="/privacy">Privacy</a>
        <a class="footer-legal-link" href="/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    font-family: 'Newsreader', serif;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(222 225 247 / 0.72);
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: #eac290;
  }

  .footer-legal-link {
    font-family: 'Newsreader', serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(210 196 183 / 0.75);
    transition: color 0.3s ease;
  }

  .footer-legal-link:hover {
    color: #eac290;
  }
</style>
