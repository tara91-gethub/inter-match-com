---
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  links?: Array<Link>;
}

export interface Props {
  id?: string;
  links?: Array<Link>;
  actions?: Array<{ text: string; href: string }>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  showToggleTheme = true,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, dark: isDark },
    'top-0 z-50 w-full border-b border-[#4e453b] bg-[#0e1322] transition-colors duration-300',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="flex justify-between items-center px-6 md:px-12 py-6 max-w-none">

    <!-- Logo -->
    <a href={getHomePermalink()} class="flex items-center">
      <Logo />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-10" aria-label="Main navigation">
      {links.map(({ text, href, links: subLinks }) => (
        <div class="relative group">
          {subLinks?.length ? (
            <>
              <button
                type="button"
                class="font-['Noto_Serif'] uppercase tracking-[0.25em] text-[0.75rem] text-white/70 hover:text-[#eac290] transition-colors duration-300 flex items-center gap-1"
              >
                {text}
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul class="absolute left-0 top-full z-50 hidden min-w-[180px] border border-[#4e453b] bg-[#161b2b] group-hover:block group-focus-within:block">
                {subLinks.map(({ text: text2, href: href2 }) => (
                  <li>
                    <a
                      href={href2}
                      class:list={[
                        'block px-6 py-3 font-["Noto_Serif"] uppercase tracking-[0.2em] text-[0.65rem] text-white/60 hover:text-[#eac290] hover:bg-[#1a1f2f] transition-colors duration-200 whitespace-nowrap',
                        { 'text-[#eac290]': href2 === currentPath },
                      ]}
                    >
                      {text2}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a
              href={href}
              class:list={[
                'font-["Noto_Serif"] uppercase tracking-[0.25em] text-[0.75rem] text-white/70 hover:text-[#eac290] transition-colors duration-300',
                { 'text-[#eac290]': href === currentPath },
              ]}
            >
              {text}
            </a>
          )}
        </div>
      ))}
    </nav>

    <!-- Right side: theme toggle + CTA -->
    <div class="hidden md:flex items-center gap-6">
      {showToggleTheme && <ToggleTheme iconClass="w-5 h-5 text-white/60 hover:text-[#eac290] transition-colors" />}
      {actions.map(({ text, href }) => (
        <a
          href={href}
          class="font-['Noto_Serif'] uppercase tracking-[0.25em] text-[0.75rem] bg-[#cda777] text-[#573c15] px-6 py-3 hover:bg-[#eac290] transition-colors duration-300"
        >
          {text}
        </a>
      ))}
    </div>

    <!-- Mobile menu toggle -->
    <div class="flex items-center md:hidden">
      {showToggleTheme && <ToggleTheme iconClass="w-5 h-5 text-white/60 mr-3" />}
      <ToggleMenu />
    </div>

  </div>

  <!-- Mobile Nav -->
  <div
    class="md:hidden hidden bg-[#0e1322] border-t border-[#4e453b] px-6 py-6 space-y-4"
    id="mobile-menu"
  >
    {links.map(({ text, href, links: subLinks }) => (
      <div>
        {subLinks?.length ? (
          <>
            <p class="font-['Noto_Serif'] uppercase tracking-[0.25em] text-[0.75rem] text-white/50 mb-2">{text}</p>
            {subLinks.map(({ text: text2, href: href2 }) => (
              <a
                href={href2}
                class="block pl-4 py-2 font-['Noto_Serif'] uppercase tracking-[0.2em] text-[0.65rem] text-white/60 hover:text-[#eac290] transition-colors"
              >
                {text2}
              </a>
            ))}
          </>
        ) : (
          <a
            href={href}
            class="block font-['Noto_Serif'] uppercase tracking-[0.25em] text-[0.75rem] text-white/70 hover:text-[#eac290] transition-colors"
          >
            {text}
          </a>
        )}
      </div>
    ))}
    {actions.map(({ text, href }) => (
      <a
        href={href}
        class="block w-full text-center font-['Noto_Serif'] uppercase tracking-[0.25em] text-[0.75rem] bg-[#cda777] text-[#573c15] px-6 py-3 hover:bg-[#eac290] transition-colors duration-300 mt-4"
      >
        {text}
      </a>
    ))}
  </div>
</header>

<script>
  const toggleMenu = document.querySelector('[data-aw-toggle-menu]');
  const mobileMenu = document.getElementById('mobile-menu');
  if (toggleMenu && mobileMenu) {
    toggleMenu.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
