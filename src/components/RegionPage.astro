---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/JsonLd.astro';
export interface Card { title: string; href: string; image: string; }
export interface LinkItem { text: string; href: string; }
export interface Props {
  metadata: { title: string; description: string };
  eyebrow: string;
  hero: string;
  body: string;
  image: string;
  cards?: Card[];
  links?: LinkItem[];
  schema: Record<string, unknown>;
}
const { metadata, eyebrow, hero, body, image, cards = [], links = [], schema } = Astro.props;
---
<Layout metadata={metadata}>
  <JsonLd data={schema} />
  <main transition:animate="fade">
    <header class="relative flex min-h-[100svh] items-center overflow-hidden pb-16 pt-28 md:pt-24">
      <div class="absolute inset-0 z-0">
        <img class="w-full h-full object-cover opacity-40" alt={hero} src={image} />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0e1322] via-transparent to-transparent"></div>
      </div>
      <div class="container z-10 mx-auto grid grid-cols-12 gap-6 px-6 md:px-12">
        <div class="col-span-12 lg:col-span-8">
          <span class="text-[#eac290] uppercase tracking-[0.25em] text-[0.75rem] mb-6 block" style="font-family:'Newsreader',serif;">{eyebrow}</span>
          <h1 class="mb-8 text-4xl leading-tight text-white sm:text-5xl md:text-7xl lg:text-8xl" style="font-family:'Noto Serif',serif;">{hero}</h1>
          <p class="max-w-xl text-lg leading-relaxed text-[#d2c4b7] md:text-xl" style="font-family:'Newsreader',serif;">Private matchmaking for discerning professionals, delivered with absolute discretion.</p>
        </div>
      </div>
    </header>
    <section class="border-b border-[#4e453b]/30 bg-[#161b2b] py-20 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <div class="grid grid-cols-12 items-center gap-10 md:gap-12">
          <div class="col-span-12 lg:order-1 lg:col-span-5"><div class="border border-[#4e453b] p-2"><img class="h-[280px] w-full object-cover grayscale transition-all duration-700 hover:grayscale-0 sm:h-[340px] md:h-[520px]" alt={hero} src={image} /></div></div>
          <div class="col-span-12 text-center lg:order-2 lg:col-span-6 lg:pl-20 lg:text-left">
            <span class="mb-4 block text-[0.7rem] uppercase tracking-[0.24em] text-[#eac290]" style="font-family:'Newsreader',serif;">The Bureau</span>
            <h2 class="mx-auto mb-6 max-w-sm text-3xl leading-tight text-white md:mb-10 md:max-w-none md:text-5xl lg:mx-0" style="font-family:'Noto Serif',serif;">{hero}</h2>
            <div class="mx-auto mb-8 h-px w-16 bg-[#eac290] lg:mx-0"></div>
            <div class="mx-auto max-w-xl bg-[#0e1322]/45 p-6 text-left md:bg-transparent md:p-0 lg:mx-0 lg:max-w-lg" style="font-family:'Newsreader',serif;"><p class="text-base leading-relaxed text-[#d2c4b7] md:text-lg">{body}</p></div>
          </div>
        </div>
      </div>
    </section>
    {cards.length > 0 && <section class="bg-[#0e1322] py-24 md:py-32"><div class="container mx-auto px-6 md:px-12"><div class="mb-16 text-center md:mb-24"><span class="text-[#eac290] uppercase tracking-[0.25em] text-[0.75rem] mb-4 block" style="font-family:'Newsreader',serif;">Local Bureaus</span><h2 class="text-3xl text-white md:text-6xl" style="font-family:'Noto Serif',serif;">Where We Serve</h2></div><div class="grid grid-cols-1 gap-1 md:grid-cols-2 lg:grid-cols-3">{cards.map((card) => <a href={card.href} class="relative group aspect-[3/4] overflow-hidden bg-[#25293a]"><img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-60" alt={card.title} src={card.image} /><div class="absolute inset-0 flex flex-col justify-end p-8"><h3 class="text-2xl text-[#eac290] tracking-widest uppercase mb-2" style="font-family:'Noto Serif',serif;">{card.title}</h3><p class="text-xs tracking-[0.2em] text-[#d2c4b7] uppercase opacity-0 group-hover:opacity-100 transition-opacity" style="font-family:'Newsreader',serif;">View Bureau</p></div></a>)}</div></div></section>}
    <section class="bg-[#090e1c] px-6 py-28 border-y border-[#4e453b] md:px-12 md:py-40"><div class="max-w-4xl mx-auto text-center"><h2 class="text-4xl md:text-5xl text-white mb-8" style="font-family:'Noto Serif',serif;">Begin the Dialogue</h2><p class="text-xl text-[#d2c4b7] mb-12 max-w-lg mx-auto" style="font-family:'Newsreader',serif;">Membership is strictly by application. Initiate a confidential inquiry with The Matchmaking Bureau.</p><div class="flex flex-col gap-5 sm:flex-row sm:justify-center">{links.map((link) => <a href={link.href} class="inline-block border border-[#9b8f82] px-8 py-5 text-center text-xs font-bold uppercase tracking-[0.16em] text-[#eac290] transition-colors hover:bg-[#eac290]/10 md:px-10 md:tracking-[0.25em]" style="font-family:'Noto Serif',serif;">{link.text}</a>)}<a href="/contact" class="inline-block bg-[#cda777] px-8 py-5 text-center text-xs font-bold uppercase tracking-[0.16em] text-[#573c15] transition-colors hover:bg-[#eac290] md:px-10 md:tracking-[0.25em]" style="font-family:'Noto Serif',serif;">Apply Now</a></div></div></section>
  </main>
</Layout>
