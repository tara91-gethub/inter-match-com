---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Vietnam Insights', description: 'Private matchmaking insights for Vietnam and Southeast Asia.' };
---
<Layout metadata={metadata}>
  <main transition:animate="fade" class="max-w-4xl mx-auto px-6 py-24 md:py-32 text-center">
    <p class="mb-6 text-xs uppercase tracking-[0.3em] text-[#eac290]" style="font-family:'Newsreader',serif;">The Bureau Journal</p>
    <h1 class="text-5xl md:text-7xl mb-8 text-white" style="font-family:'Noto Serif',serif;">Vietnam</h1>
    <p class="text-xl md:text-2xl text-[#9b8f82] max-w-2xl mx-auto italic leading-relaxed" style="font-family:'Newsreader',serif;">Private matchmaking notes and regional guidance for discerning professionals in Vietnam.</p>
    <div class="mt-12"><a href="/vietnam" class="inline-block bg-[#cda777] px-8 py-5 text-xs font-bold uppercase tracking-[0.16em] text-[#573c15] transition-colors hover:bg-[#eac290] md:px-10 md:tracking-[0.25em]" style="font-family:'Noto Serif',serif;">View Vietnam Bureau</a></div>
  </main>
</Layout>
