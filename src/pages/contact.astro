---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Apply Now', description: 'Apply to The Matchmaking Bureau - private matchmaking across Southeast Asia.' };
const locations = ['Manila','Cebu','Bangkok','Jakarta','Kuala Lumpur','Singapore','Ho Chi Minh City','Other'];
---
<Layout metadata={metadata}><main transition:animate="fade" class="max-w-4xl mx-auto px-6 py-24 md:py-32"><header class="mb-24 text-center"><h1 class="text-5xl md:text-7xl mb-8 tracking-[-0.02em] text-white" style="font-family:'Noto Serif',serif;">The Entry Bureau</h1><p class="text-xl md:text-2xl text-[#9b8f82] max-w-2xl mx-auto italic leading-relaxed" style="font-family:'Newsreader',serif;">Refining the search for exceptional connection. Please provide your details with the utmost discretion.</p></header><form class="space-y-32" action="https://formsubmit.co/admin@matchmakingbureau.com" method="POST"><input type="hidden" name="_subject" value="New Matchmaking Bureau International application" /><input type="hidden" name="_next" value="https://matchmakingbureau.com/contact" /><input type="hidden" name="_captcha" value="false" /><section class="space-y-12"><div class="flex items-baseline gap-4 border-b border-[#4e453b] pb-4 mb-12"><span class="text-xs tracking-widest text-[#eac290] uppercase" style="font-family:'Newsreader',serif;">01</span><h2 class="text-2xl uppercase tracking-widest text-white" style="font-family:'Noto Serif',serif;">Basic Information</h2></div><div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16"><div class="space-y-2"><label class="text-xs tracking-[0.25em] uppercase text-[#9b8f82]" style="font-family:'Newsreader',serif;">Full Legal Name <span class="text-[#eac290]">*</span></label><input name="full_name" class="w-full bg-transparent border-b border-[#4e453b] focus:border-[#eac290] px-0 py-3 text-lg transition-colors duration-300 text-white" type="text" required style="font-family:'Newsreader',serif;" /></div><div class="space-y-2"><label class="text-xs tracking-[0.25em] uppercase text-[#9b8f82]" style="font-family:'Newsreader',serif;">Email Address <span class="text-[#eac290]">*</span></label><input name="email" class="w-full bg-transparent border-b border-[#4e453b] focus:border-[#eac290] px-0 py-3 text-lg transition-colors duration-300 text-white" type="email" required style="font-family:'Newsreader',serif;" /></div><div class="space-y-2 md:col-span-2"><label class="text-xs tracking-[0.25em] uppercase text-[#9b8f82]" style="font-family:'Newsreader',serif;">Current Location <span class="text-[#eac290]">*</span></label><select name="location" required class="w-full bg-[#0e1322] border-b border-[#4e453b] focus:border-[#eac290] px-0 py-3 text-lg transition-colors duration-300 text-white appearance-none" style="font-family:'Newsreader',serif;">{locations.map((location) => <option>{location}</option>)}</select></div></div></section><section class="space-y-12"><div class="flex items-baseline gap-4 border-b border-[#4e453b] pb-4 mb-12"><span class="text-xs tracking-widest text-[#eac290] uppercase" style="font-family:'Newsreader',serif;">02</span><h2 class="text-2xl uppercase tracking-widest text-white" style="font-family:'Noto Serif',serif;">Professional Background</h2></div><div class="space-y-16"><div class="space-y-2"><label class="text-xs tracking-[0.25em] uppercase text-[#9b8f82]" style="font-family:'Newsreader',serif;">Industry and Occupation <span class="text-[#eac290]">*</span></label><input name="occupation" class="w-full bg-transparent border-b border-[#4e453b] focus:border-[#eac290] px-0 py-3 text-lg transition-colors duration-300 text-white" type="text" required style="font-family:'Newsreader',serif;" /></div><div class="space-y-2"><label class="text-xs tracking-[0.25em] uppercase text-[#9b8f82]" style="font-family:'Newsreader',serif;">Relationship Intentions</label><textarea name="intentions" class="w-full bg-transparent border-b border-[#4e453b] focus:border-[#eac290] px-0 py-3 text-lg transition-colors duration-300 resize-none text-white" rows="4" style="font-family:'Newsreader',serif;"></textarea></div></div></section><section class="space-y-12 pt-12"><label class="flex items-start gap-4 cursor-pointer group"><input name="discretion_agreement" value="Accepted" required class="mt-1 w-5 h-5 border border-[#4e453b] bg-transparent accent-[#eac290] cursor-pointer" type="checkbox" /><span class="text-sm leading-relaxed text-[#9b8f82] group-hover:text-white transition-colors" style="font-family:'Newsreader',serif;">I understand that The Matchmaking Bureau operates with absolute discretion. <span class="text-[#eac290]">*</span></span></label><button type="submit" class="w-full bg-[#cda777] text-[#573c15] text-sm tracking-[0.3em] uppercase py-6 transition-all duration-300 hover:bg-[#eac290]" style="font-family:'Newsreader',serif;">Submit Application</button></section></form></main></Layout>
