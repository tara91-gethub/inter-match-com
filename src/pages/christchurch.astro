---
import '~/assets/styles/tailwind.css';

const metadata = {
  title: 'Christchurch | THE REGISTRY',
  description:
    'Private matchmaking in Christchurch for discerning South Island professionals seeking discreet, curated introductions.',
};
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;700&family=Newsreader:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0e1322] text-[#dee1f7] selection:bg-[#cda777] selection:text-[#573c15]">
    <nav
      class="fixed top-0 z-50 flex w-full items-center justify-between border-b border-[#4e453b] bg-[#0e1322]/95 px-5 py-5 backdrop-blur transition-colors duration-300 md:px-12 md:py-8"
    >
      <a
        class="font-headline text-lg font-bold uppercase tracking-[0.15em] text-[#cda777] md:text-xl"
        href="/christchurch"
      >
        THE REGISTRY
      </a>
      <div class="hidden items-center gap-12 md:flex">
        <a class="nav-link" href="#membership">Membership</a>
        <a class="nav-link" href="#process">Process</a>
        <a class="nav-cta" href="#apply">Apply Now</a>
      </div>
      <a class="nav-cta md:hidden" href="#apply">Apply</a>
    </nav>

    <main class="pt-20 md:pt-24">
      <section
        class="relative flex min-h-[760px] flex-col items-center justify-center overflow-hidden border-b border-[#4e453b] px-5 py-28 md:min-h-[880px] md:px-12 md:py-32"
      >
        <div class="absolute inset-0 z-0">
          <img
            class="h-full w-full object-cover opacity-40 grayscale"
            alt="Cinematic wide shot of Christchurch cathedral square at twilight with historic architecture and warm golden street lights reflecting on wet pavement"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCqpEFbfMpIEBnUlM7M3U8KT5jkgUGRud8yMcQHOsoHZmXNhCeXZdxIR6wyHd3mIJskK7T0ejBkwgNtkjGDdTRJ0KWdyrv8ps0OGnGoAj0DoZD2PIwZEncmAvQJ8jzJFgb7lEwoB4_ns01URAWJRvqRKaXeIy1gmAnIj84Z-qPmU4IUOj5z5f93mujsmLCk-A-xCIWW2U-IMHjKP3UkreuJ3-w6N8UC5eUMiMbrxY3gvamuZV7yGSPkEpH0lYkO1ew8q2VJwezhcfOo"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-[#0e1322]/85 via-[#0e1322]/20 to-[#0e1322]"></div>
        </div>
        <div class="relative z-10 w-full max-w-5xl text-center">
          <p class="mb-8 font-headline text-xs uppercase tracking-[0.4em] text-[#eac290]">
            Exclusive Christchurch Registry
          </p>
          <h1 class="mb-10 font-headline text-5xl leading-none text-[#dee1f7] md:mb-12 md:text-8xl">
            Private matchmaking in Christchurch
          </h1>
          <div class="mx-auto flex max-w-4xl items-center justify-center gap-5 md:gap-8">
            <div class="hidden h-px w-24 bg-[#cda777] md:block"></div>
            <p class="max-w-xl font-body text-2xl italic text-[#d2c4b7]">
              Curated introductions for the discerning elite of the South Island.
            </p>
            <div class="hidden h-px w-24 bg-[#cda777] md:block"></div>
          </div>
        </div>
      </section>

      <section id="membership" class="bg-[#0e1322] px-5 py-24 md:px-12 md:py-32">
        <div class="editorial-grid mx-auto max-w-7xl gap-12">
          <div class="col-span-12 flex flex-col justify-center md:col-span-5">
            <h2 class="mb-8 font-headline text-4xl leading-tight text-white">
              The Garden City <br />
              Refined
            </h2>
            <p class="mb-6 font-body text-xl leading-relaxed text-[#d2c4b7]">
              In the heart of Canterbury, sophistication meets heritage. Christchurch is more than a destination; it is
              a lifestyle defined by understated elegance and intellectual depth.
            </p>
            <p class="mb-12 font-body text-xl leading-relaxed text-[#d2c4b7]">
              The Match Bureau operates as a silent partner to the city's most successful professionals, providing a
              private portal to connections that traditional social circles cannot facilitate.
            </p>
            <div class="border-l-2 border-[#eac290] py-4 pl-8">
              <span class="mb-2 block font-body text-xs uppercase tracking-widest text-[#eac290]">Local Registry</span>
              <span class="block font-headline text-2xl text-[#dee1f7]">42 Selected Members</span>
            </div>
          </div>
          <div class="col-span-12 md:col-span-7">
            <div class="grid grid-cols-2 gap-4">
              <div class="aspect-[3/4] overflow-hidden bg-[#161b2b]">
                <img
                  class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
                  alt="Moody close-up of a high-end leather chair in a dark wooden paneled private library with a crystal glass on a side table"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuDoCvbL5kQtJptsaqA6Zrl7uoIAbpdl6BNSpCr-IVVrOKBs2nfSglQdnbtIuvMpOLmfvzrkKzXs4Xnt0ZD8lwZMnDCVrr8cMtQnGip3HVMN2rcVZwhqMiPSK6fSHSfeb75DwK5JCShkEqH8sM3thpoqpDUkv6mjvW1Ii7usSijpDs2jqOg-QkuchvpZbPAaTshMGCosPbuwpZn4EF2MvFakDaOCo4CiF8cYA5QNnLmSpE40dC2JU_2hRACR5qUUGTjzUVCX1gtea6s2"
                />
              </div>
              <div class="mt-12 aspect-[3/4] overflow-hidden bg-[#161b2b]">
                <img
                  class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
                  alt="Elegant dining table setting in a luxury Christchurch restaurant with candlelight, fine porcelain, and silver cutlery"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuCv0oFqfb_8Bd4b2t7adn8aFaKlJ6PcGtvHynJVOz5h-rHhZ2GUoU8q4FfzsYmwYRO6A3d8vFRVbRCIK0UZuwGAAxZRudNcTJCfCj8_o7NTuV564CNYqKy32aClJcb-cgHH1hGoa0QIU2LnJhel8gf1D316-DlD09g7MRYEtHH6Hl2hkEJVeQbhilryPXW_DkmpNC4v5qmiHULXviAlzxtl7Ip-FfLlrXIzIrSIGiAGiknd01o2pn33jN7_mjepheORmFcZ5ASX__nJ"
                />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="process" class="bg-[#161b2b] px-5 py-24 md:px-12 md:py-32">
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center md:mb-24">
            <h2 class="mb-4 font-headline text-5xl text-white">The Monolith Process</h2>
            <p class="font-body text-sm uppercase tracking-[0.3em] text-[#eac290]">Four Pillars of Connection</p>
          </div>
          <div class="grid grid-cols-1 gap-px md:grid-cols-4">
            <article class="process-card">
              <span>01</span>
              <div>
                <h3>The Inquiry</h3>
                <p>
                  An initial vetting phase ensuring all candidates meet the Registry's threshold for professional and
                  personal excellence.
                </p>
              </div>
            </article>
            <article class="process-card">
              <span>02</span>
              <div>
                <h3>Psychological Mapping</h3>
                <p>
                  Deep-dive interviews to understand core values, lifestyle aspirations, and the architectural blueprint
                  of your ideal partner.
                </p>
              </div>
            </article>
            <article class="process-card">
              <span>03</span>
              <div>
                <h3>The Curation</h3>
                <p>
                  Our consultants hand-select potential matches from our private ledger, presenting only those with
                  absolute compatibility.
                </p>
              </div>
            </article>
            <article class="process-card">
              <span>04</span>
              <div>
                <h3>The Encounter</h3>
                <p>
                  Discreetly coordinated introductions at Christchurch's most exclusive venues, overseen with
                  concierge-level detail.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="px-0 py-0">
        <div class="relative h-[600px] w-full overflow-hidden grayscale brightness-50 contrast-125">
          <div class="absolute inset-0 z-10 bg-[#0e1322] mix-blend-multiply"></div>
          <img
            class="h-full w-full object-cover"
            alt="Abstract aerial view of Christchurch urban grid at night with glowing amber lights and dark shadow pockets"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCwWppE4atO32SXJs1G5rCxOfZtSL5rcqMav85yfVNtBGEkHBchL40dTfyLoRZ-qZsvyJxbdOV8XQWLOu3Wz-gqyt6Ued9ztaRadryLNHPoMs-JEQoKmRJFbUN9R0pDsWUPyNeBH5bqOWhiBdDPxN10lM0MT2ouV8g49436RzM4bdgId9gWsLC4NLhotTxmECYogyBqgX8gAnczyF3XNwoVW3W9xIB7GM6MJSae5Yfaz_kMVSspg16YS95UVOxGxXkQg3GuF8GgTOfF"
          />
          <div class="absolute inset-0 z-20 flex items-center justify-center px-5">
            <div class="text-center">
              <span class="material-symbols-outlined mb-4 text-6xl text-[#eac290] icon-filled">location_on</span>
              <h3 class="font-headline text-4xl uppercase tracking-widest text-white">Canterbury Operations</h3>
              <p class="mt-4 font-body text-sm uppercase tracking-[0.2em] text-[#eac290]">
                Private Consultations by Appointment Only
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="apply" class="bg-[#0e1322] px-5 py-24 text-center md:px-12 md:py-32">
        <div class="mx-auto max-w-3xl">
          <h2 class="mb-8 font-headline text-5xl leading-tight text-white">
            Secure your place in <br />
            The Registry.
          </h2>
          <p class="mb-12 font-body text-xl text-[#d2c4b7]">
            Membership is strictly limited to ensure the highest quality of introductions within the Christchurch
            metropolitan area.
          </p>
          <div class="flex flex-col items-center justify-center gap-6 md:flex-row">
            <a class="cta-primary" href="mailto:hello@thematchbureau.co.nz">Apply for Christchurch</a>
            <a class="cta-secondary" href="mailto:hello@thematchbureau.co.nz?subject=Christchurch%20brochure">
              Request a Brochure
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="w-full bg-[#161b2b] pb-12 pt-24">
      <div class="mx-auto flex max-w-7xl flex-col items-center px-5 text-center md:px-12">
        <span class="mb-8 block font-headline text-2xl font-bold uppercase tracking-[0.15em] text-[#cda777]">
          THE REGISTRY
        </span>
        <div class="mb-12 flex flex-wrap justify-center gap-8 md:gap-12">
          <a class="footer-link" href="/privacy">Privacy</a>
          <a class="footer-link" href="/terms">Terms</a>
          <a class="footer-link" href="#membership">Press</a>
          <a class="footer-link" href="mailto:hello@thematchbureau.co.nz">Contact</a>
        </div>
        <div class="mb-12 h-px w-24 bg-[#4e453b]"></div>
        <p class="font-body text-[0.65rem] uppercase tracking-[0.2em] text-white/40">
          (c) 2026 THE REGISTRY ARCHITECTURAL MONOLITH. ALL RIGHTS RESERVED.
        </p>
        <p class="mt-4 font-body text-[0.6rem] uppercase tracking-widest text-[#cda777]/50">
          Established in New Zealand
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    font-family: 'Newsreader', serif;
    background-color: #0e1322;
  }

  .font-headline {
    font-family: 'Noto Serif', serif;
  }

  .font-body {
    font-family: 'Newsreader', serif;
  }

  .material-symbols-outlined {
    font-variation-settings:
      'FILL' 0,
      'wght' 300,
      'GRAD' 0,
      'opsz' 24;
  }

  .material-symbols-outlined.icon-filled {
    font-variation-settings:
      'FILL' 1,
      'wght' 300,
      'GRAD' 0,
      'opsz' 48;
  }

  .nav-link {
    font-family: 'Noto Serif', serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.7);
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: #eac290;
  }

  .nav-cta,
  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Noto Serif', serif;
    text-transform: uppercase;
    transition:
      background-color 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .nav-cta {
    background-color: #cda777;
    padding: 0.8rem 1.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: #573c15;
  }

  .nav-cta:hover,
  .cta-primary:hover {
    background-color: #eac290;
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
  }

  .process-card {
    display: flex;
    min-height: 24rem;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid #4e453b;
    background-color: #0e1322;
    padding: 2.5rem;
  }

  .process-card span {
    font-family: 'Noto Serif', serif;
    font-size: 2.5rem;
    color: rgb(234 194 144 / 0.3);
  }

  .process-card h3 {
    margin-bottom: 1rem;
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .process-card p {
    font-family: 'Newsreader', serif;
    line-height: 1.6;
    color: #d2c4b7;
  }

  .cta-primary,
  .cta-secondary {
    min-height: 3.75rem;
    width: 100%;
    padding: 1rem 2rem;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }

  .cta-primary {
    background-color: #cda777;
    color: #573c15;
  }

  .cta-secondary {
    border: 1px solid #9b8f82;
    color: #eac290;
  }

  .cta-secondary:hover {
    background-color: rgb(234 194 144 / 0.1);
    border-color: #eac290;
  }

  .footer-link {
    font-family: 'Noto Serif', serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.4);
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: #ffffff;
  }

  @media (min-width: 768px) {
    .cta-primary,
    .cta-secondary {
      width: auto;
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }

  @media (max-width: 767px) {
    .editorial-grid {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    .process-card {
      min-height: 20rem;
      padding: 2rem;
    }
  }
</style>
