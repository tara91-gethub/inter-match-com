---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Private Matchmaking in Christchurch',
  description: 'The Match Bureau Christchurch — discreet introductions for the discerning elite of the Garden City and Canterbury region.',
};
---

<Layout metadata={metadata}>
  <main transition:animate="fade">

    <!-- Hero -->
    <section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 bg-black/50 z-10"></div>
      <img class="absolute inset-0 w-full h-full object-cover" alt="Christchurch NZ CBD and Cathedral Square at night" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB8guKnG64gR7xj2Fq_mxJWaRuvpPX6TaxeV8D-8sbW4Q7ohf1RU1xJ70Js0eqSGUz9s0D9P_RWMiayaE9gwklZPshNqI7LYYy2L16kzHr4mFkQsnz-Em2mwRb4f8MkZuITD4vcsM74j-RggIvjtv_SYCBl1aPn_yCVzCtmzBkUrDk-T1QomaQcbgLJiiuOP06A9IvYzHULovNxjb4zfuFL13XbLDJDX5ZGYsFu8oSaaMhIGRlOHL7VVJ3rIke6EPwNp73vxRXlnFO7" />
      <div class="relative z-20 text-center px-4 max-w-5xl">
        <span class="block text-[#eac290] uppercase tracking-[0.2em] mb-6 text-sm" style="font-family:'Newsreader',serif;">ESTABLISHED IN THE SOUTH ISLAND</span>
        <h1 class="text-white leading-tight mb-8 text-5xl md:text-7xl lg:text-8xl" style="font-family:'Noto Serif',serif;">
          Private matchmaking in Christchurch, New Zealand
        </h1>
        <p class="text-xl md:text-2xl text-[#d2c4b7] italic opacity-80" style="font-family:'Newsreader',serif;">
          The Garden City, Reimagined.
        </p>
      </div>
    </section>

    <!-- Heritage Section -->
    <section class="py-32 px-12 bg-[#0e1322]">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-5 space-y-12">
          <h2 class="text-4xl md:text-5xl text-[#eac290] leading-tight" style="font-family:'Noto Serif',serif;">The Heritage of Resilience</h2>
          <div class="space-y-6 text-lg leading-relaxed text-[#d2c4b7]" style="font-family:'Newsreader',serif;">
            <p>Christchurch is a city defined by its ability to evolve without losing its soul. It is a tapestry of neo-gothic stone and cutting-edge architectural innovation, nestled between the Pacific and the Southern Alps.</p>
            <p>Our approach in the South Island reflects this duality. We blend old-world matchmaking values — discretion, integrity, and depth — with the modern sensibilities of Christchurch's thriving entrepreneurial and creative class.</p>
          </div>
          <div class="border-l border-[#eac290] pl-8 py-4">
            <p class="italic text-xl text-white" style="font-family:'Newsreader',serif;">"A refined ecosystem where tradition meets the vanguard of New Zealand culture."</p>
          </div>
        </div>
        <div class="lg:col-span-7 grid grid-cols-2 gap-4 h-[600px]">
          <div class="relative h-full pt-12">
            <img class="w-full h-full object-cover" alt="Avon River through Christchurch Botanic Gardens" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBO2jwDwnL5eQbgO-NS13jRMAh6_JKQ695By7SsE0OJyHPvYOMO3FYENBGj_lUc7EuNlg2f1TdQDgjwQYXL_zdrwI9fmgD30FMwhGIZV2PbyZcqGyXHn1CfGw3KyYolnu4ozk82eFECPSH_BgHPT7vLDnTuGjC8hmDUViXyOjUG5PQaV4FrjKg43qY3RnVqJK-gKtOmhofigcRK_Y5kOoRUTLM1glCl_f6QIif4GNIV1cPL571byHB7hBJcdFxGk5UtItG7-NJvHSe4" />
          </div>
          <div class="relative h-full pb-12">
            <img class="w-full h-full object-cover" alt="Canterbury Plains at dusk with Southern Alps" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBfp-DyR7CbE-ZaYh4BGSlzNnajYA4n-G8BVrc6lTJdZNS8T_SFOWtLgzcbUr8NDJ0VxlNc0A31agFwJD8o3J4yyG_ftpsUPTQvS6YFifUcm8N1aGDyzTSL_GmraG1Xby84ipCPm5XQgxzWozVMP3vj5NGwPeUpcAAFXy0DPyp0_Y46dVz2h3h4W7e1OFfZISgg2heJQfk5ejB1RcrGXOZZIZPvzDPpv5ezJmEAZxnHljme3fVDlyC-gwApVgjjsGRMAoc_Sn7U2jp9" />
          </div>
        </div>
      </div>
    </section>

    <!-- The Protocol -->
    <section class="py-32 px-12 bg-[#161b2b]">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
          <div>
            <span class="text-[#eac290] tracking-[0.2em] text-xs uppercase block mb-4" style="font-family:'Newsreader',serif;">OUR ARCHITECTURAL APPROACH</span>
            <h2 class="text-4xl md:text-6xl text-white" style="font-family:'Noto Serif',serif;">The Protocol</h2>
          </div>
          <p class="max-w-md text-[#d2c4b7] italic" style="font-family:'Newsreader',serif;">A precision-led curation process designed for New Zealand's most discerning individuals.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-[#4e453b]">
          <div class="p-12 border-b md:border-b-0 md:border-r border-[#4e453b] bg-[#0e1322] hover:bg-[#25293a] transition-colors group">
            <span class="text-[#eac290] text-4xl block mb-8" style="font-family:'Noto Serif',serif;">01</span>
            <h3 class="text-white text-2xl mb-6 uppercase tracking-wider" style="font-family:'Noto Serif',serif;">Intake</h3>
            <p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">A deep-dive consultation to understand your architectural blueprint — your values, your history, and your vision for the future.</p>
            <div class="mt-12 h-1 w-0 bg-[#eac290] group-hover:w-full transition-all duration-500"></div>
          </div>
          <div class="p-12 border-b md:border-b-0 md:border-r border-[#4e453b] bg-[#0e1322] hover:bg-[#25293a] transition-colors group">
            <span class="text-[#eac290] text-4xl block mb-8" style="font-family:'Noto Serif',serif;">02</span>
            <h3 class="text-white text-2xl mb-6 uppercase tracking-wider" style="font-family:'Noto Serif',serif;">Curation</h3>
            <p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">We leverage our exclusive Christchurch and Southern network to identify individuals who align with your personal aesthetic and intellect.</p>
            <div class="mt-12 h-1 w-0 bg-[#eac290] group-hover:w-full transition-all duration-500"></div>
          </div>
          <div class="p-12 bg-[#0e1322] hover:bg-[#25293a] transition-colors group">
            <span class="text-[#eac290] text-4xl block mb-8" style="font-family:'Noto Serif',serif;">03</span>
            <h3 class="text-white text-2xl mb-6 uppercase tracking-wider" style="font-family:'Noto Serif',serif;">Integration</h3>
            <p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">Managed introductions designed to foster meaningful connection within the city's most elegant social and cultural contexts.</p>
            <div class="mt-12 h-1 w-0 bg-[#eac290] group-hover:w-full transition-all duration-500"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-40 bg-[#0e1322] flex justify-center">
      <div class="max-w-4xl text-center px-12 border-y border-[#4e453b] py-24">
        <div class="text-[#eac290] text-5xl mb-12">"</div>
        <blockquote class="text-3xl md:text-5xl text-white leading-tight italic" style="font-family:'Noto Serif',serif;">
          "The Match Bureau operates with a level of sophistication previously unseen in the New Zealand market. They don't just find matches; they curate synergies that reflect the refined pace of Christchurch life."
        </blockquote>
        <cite class="block mt-12 text-[#eac290] uppercase tracking-[0.2em] text-sm not-italic" style="font-family:'Newsreader',serif;">— Private Member, Fendalton</cite>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 px-12">
      <div class="bg-[#2f3445] p-16 md:p-24 flex flex-col md:flex-row items-center justify-between gap-12 border border-[#eac290]/20">
        <div class="max-w-xl">
          <h2 class="text-4xl md:text-6xl text-white mb-6" style="font-family:'Noto Serif',serif;">Begin the Dialogue</h2>
          <p class="text-[#d2c4b7] text-lg" style="font-family:'Newsreader',serif;">Entry into the bureau is by application only. Our Christchurch lead will contact you for a private briefing.</p>
        </div>
        <a href="/contact" class="inline-block bg-[#eac290] text-[#442b06] px-16 py-6 text-sm font-bold tracking-[0.3em] uppercase hover:bg-[#cda777] transition-colors whitespace-nowrap" style="font-family:'Noto Serif',serif;">
          APPLY NOW
        </a>
      </div>
    </section>

  </main>
</Layout>
