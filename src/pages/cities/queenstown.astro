---
import Layout from '~/layouts/PageLayout.astro';
import CitySeoLinks from '~/components/CitySeoLinks.astro';

const metadata = {
  title: 'Private Matchmaking in Queenstown',
  description: 'The Matchmaking Bureau Queenstown — bespoke introductions for discerning individuals amid alpine luxury and the Southern Lakes.',
};
---

<Layout metadata={metadata}>
  <main transition:animate="fade">

    <section class="relative h-[921px] w-full flex items-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img class="w-full h-full object-cover opacity-60" alt="Snow-capped Southern Alps reflecting in Lake Wakatipu at dusk" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBd3nrZrssZDzuNoFoTyyofkYaQ5TOA4utAxYdM5LYDGzaFiLCyi_KXN8XfcQIBE2Bj39Q4V4hfgLrvWaOly4FTI5wIv6a1f57kPbfx67CfOaz_LzLn4DlSm8omeqJRGUS3S5p_JRK3y-lo7UmoCbCLn552flXSXaIAoC0qQJKL_lVnQtwLXedmQ3vTZIASxYAgFWmjBNJCqP7nflrm6uolTuBgNcedMhDapxWNbfNNa7THUUjDFn9Mz6UfAqcANrRAmzwBSXBk6kgE" />
        <div class="absolute inset-0 bg-gradient-to-r from-[#0e1322] via-transparent to-transparent"></div>
      </div>
      <div class="container mx-auto px-6 md:px-12 relative z-10">
        <div class="max-w-4xl">
          <span class="uppercase tracking-[0.4em] text-[#eac290] text-xs mb-6 block" style="font-family:'Newsreader',serif;">Queenstown Chapter</span>
          <h1 class="text-5xl md:text-8xl font-light text-white leading-tight mb-8" style="font-family:'Noto Serif',serif;">
            Private matchmaking in <br/><span class="italic text-[#eac290]">Queenstown</span>
          </h1>
          <p class="text-xl md:text-2xl text-[#d2c4b7] max-w-2xl leading-relaxed mb-12" style="font-family:'Newsreader',serif;">
            For those who seek connection amidst alpine luxury and intimate retreats. Our bespoke service caters to the South Island's most discerning individuals.
          </p>
          <div class="flex flex-col md:flex-row gap-6">
            <a href="/contact" class="bg-[#cda777] text-[#573c15] px-10 py-5 uppercase tracking-[0.2em] text-xs font-bold hover:bg-[#eac290] transition-colors" style="font-family:'Noto Serif',serif;">
              Request an Introduction
            </a>
            <a href="/process" class="border border-[#9b8f82] text-[#eac290] px-10 py-5 uppercase tracking-[0.2em] text-xs font-bold hover:bg-[#eac290]/10 transition-colors" style="font-family:'Noto Serif',serif;">
              Our Methodology
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#0e1322] py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <div class="grid grid-cols-12 gap-12 items-start">
          <div class="col-span-12 md:col-span-5">
            <h2 class="text-3xl md:text-5xl text-white font-light leading-snug mb-8" style="font-family:'Noto Serif',serif;">
              A sanctuary for <br/>sophisticated <span class="italic">unions</span>.
            </h2>
          </div>
          <div class="col-span-12 md:col-span-6 md:col-start-7">
            <p class="text-lg md:text-xl text-[#d2c4b7] leading-relaxed mb-8" style="font-family:'Newsreader',serif;">
              Queenstown is more than a destination; it is a lifestyle defined by breathtaking landscapes and uncompromised excellence. The Matchmaking Bureau operates within this exclusive sphere, facilitating connections for high-net-worth individuals, creative visionaries, and discerning New Zealanders who call the Southern Alps home.
            </p>
            <p class="text-lg md:text-xl text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">
              We understand the value of discretion. In a town where everyone knows a name, we ensure your search for a life partner remains entirely private, focusing on intellectual alignment and shared values rather than mere proximity.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-[#4e453b] bg-[#161b2b] py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <div class="mb-24 text-center">
          <span class="uppercase tracking-[0.3em] text-[#eac290] text-xs mb-4 block" style="font-family:'Newsreader',serif;">The Journey</span>
          <h2 class="text-4xl md:text-6xl text-white font-light" style="font-family:'Noto Serif',serif;">How It Works</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
          <div class="group relative border-b border-[#4e453b] bg-[#0e1322] p-8 transition-colors duration-500 hover:bg-[#1a1f2f] md:border-b-0 md:border-r md:p-12">
            <span class="text-6xl text-[#4e453b] opacity-30 absolute top-8 right-8" style="font-family:'Noto Serif',serif;">01</span>
            <h3 class="text-2xl text-[#eac290] mb-6 uppercase tracking-widest" style="font-family:'Noto Serif',serif;">The Consultation</h3>
            <p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">
              An intimate dialogue to understand your history, aspirations, and the non-negotiables of your future partner. Conducted at a private lounge or your preferred retreat.
            </p>
          </div>
          <div class="group relative border-b border-[#4e453b] bg-[#0e1322] p-8 transition-colors duration-500 hover:bg-[#1a1f2f] md:border-b-0 md:border-r md:p-12">
            <span class="text-6xl text-[#4e453b] opacity-30 absolute top-8 right-8" style="font-family:'Noto Serif',serif;">02</span>
            <h3 class="text-2xl text-[#eac290] mb-6 uppercase tracking-widest" style="font-family:'Noto Serif',serif;">The Search</h3>
            <p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">
              We leverage our deep-rooted network across Queenstown, Wanaka, Auckland, Wellington, and Christchurch to source candidates who meet our rigorous standards of character and stature.
            </p>
          </div>
          <div class="group relative bg-[#0e1322] p-8 transition-colors duration-500 hover:bg-[#1a1f2f] md:p-12">
            <span class="text-6xl text-[#4e453b] opacity-30 absolute top-8 right-8" style="font-family:'Noto Serif',serif;">03</span>
            <h3 class="text-2xl text-[#eac290] mb-6 uppercase tracking-widest" style="font-family:'Noto Serif',serif;">The Introduction</h3>
            <p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">
              Curated first meetings in the region's most exclusive venues. We handle the logistics, ensuring the environment is as exceptional as the company.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#0e1322] py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <div class="grid grid-cols-12 gap-12">
          <div class="col-span-12 md:col-span-7">
            <img class="h-[420px] w-full object-cover grayscale brightness-75 transition-all duration-700 hover:grayscale-0 md:h-[600px]" alt="Luxury alpine interior with stone fireplace" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDdh9hiPy1ghkuHJXfY8jjO-seAc2tr5M2EK8MRipfayBjGqCP_n0US4BgNoYqVxzGLsSmzgBFkbqyrqZpxWAkDBZP1Rgr94PlNoWok0tezwPt6-Y3Jcl-cGXXqT3FaqVjgLPjOSJLEnJWUuJd_lEZwwPHREJ65xf0K2fQ9PqGXNiBgMTHxYhMF-RPh6DItB-1M-qtb0dJ0CiPdujRBSAUM0v9Fx7WgSFo92emyBB2AFzbrzt8Bprn4VjrL2vEJJHT3myq8d3OD8m2" />
          </div>
          <div class="col-span-12 md:col-span-4 md:col-start-9 flex flex-col justify-center">
            <div class="border border-[#4e453b] bg-[#25293a] p-8 md:p-10">
              <h4 class="text-2xl text-white mb-6 italic" style="font-family:'Noto Serif',serif;">"Integrity is the only currency that matters in our circles."</h4>
              <p class="text-[#d2c4b7] mb-8 leading-relaxed" style="font-family:'Newsreader',serif;">
                Our Queenstown members often balance private ambition with a distinctly New Zealand way of life. We provide the stability and precision needed to find a partner who understands that rhythm.
              </p>
              <span class="uppercase tracking-widest text-[#eac290] text-xs" style="font-family:'Newsreader',serif;">— SENIOR MATCHMAKER, QUEENSTOWN</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-[#4e453b] bg-[#0e1322] py-28 text-center md:py-40">
      <div class="container mx-auto px-6 max-w-3xl">
        <h2 class="text-4xl md:text-7xl text-white font-light mb-12 leading-tight" style="font-family:'Noto Serif',serif;">
          Begin your <br/><span class="italic text-[#eac290]">new chapter</span>
        </h2>
        <p class="text-xl text-[#d2c4b7] mb-16 leading-relaxed" style="font-family:'Newsreader',serif;">
          Entry into The Matchmaking Bureau is by invitation or application. Start your journey by submitting a confidential profile for our review.
        </p>
        <a href="/contact" class="inline-block bg-[#cda777] px-10 py-6 text-sm font-bold uppercase tracking-[0.3em] text-[#573c15] transition-colors hover:bg-[#eac290] md:px-16" style="font-family:'Noto Serif',serif;">
          Apply for Membership
        </a>
      </div>
    </section>

    <CitySeoLinks currentCity="Queenstown" />

  </main>
</Layout>
