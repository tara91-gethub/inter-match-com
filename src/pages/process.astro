---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/JsonLd.astro';
const metadata = { title: 'The Process', description: 'How The Matchmaking Bureau works - private matchmaking across Southeast Asia, from application to introduction.' };
const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Private Matchmaking Service",
  "provider": {
    "@type": "Organization",
    "name": "The Matchmaking Bureau",
    "url": "https://matchmakingbureau.com"
  },
  "areaServed": [
    "Philippines",
    "Thailand",
    "Indonesia",
    "Malaysia",
    "Singapore",
    "Vietnam"
  ],
  "description": "Hand-selected private introductions for discerning professionals across Southeast Asia.",
  "serviceType": "Matchmaking"
};
const steps = [['01','The Application','A confidential application establishes intent, values, lifestyle context and regional preferences.'],['02','The Consultation','A private conversation gives our consultants the nuance no algorithm can understand.'],['03','The Search','Our team reviews trusted circles across Southeast Asia and curates only compatible possibilities.'],['04','The Introduction','A single introduction is arranged with discretion and careful context.'],['05','Ongoing Support','Feedback refines the search and protects the integrity of each step.']];
---
<Layout metadata={metadata}><JsonLd data={schema} /><main transition:animate="fade"><section class="relative h-[614px] flex flex-col items-center justify-center text-center px-6 overflow-hidden"><p class="tracking-[0.24em] uppercase text-[#eac290] mb-6 text-xs md:tracking-[0.4em]" style="font-family:'Newsreader',serif;">The Methodology of Excellence</p><h1 class="mb-8 text-5xl tracking-tight text-white md:text-8xl lg:text-9xl" style="font-family:'Noto Serif',serif;">The Process</h1><div class="w-24 h-1 bg-[#eac290]"></div></section><section class="space-y-32 px-6 py-24 md:space-y-48 md:px-24 md:py-32 lg:px-48">{steps.map(([number,title,text], index) => <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start"><div class:list={['md:col-span-4', index % 2 === 1 && 'md:order-2']}><span class="block text-6xl leading-none text-[#eac290]/20 md:text-8xl lg:text-9xl" style="font-family:'Noto Serif',serif;">{number}</span><div class="w-full h-px bg-[#4e453b] mt-8"></div></div><div class:list={['md:col-span-8 pt-4', index % 2 === 1 && 'md:order-1 md:text-right md:flex md:flex-col md:items-end']}><h2 class="text-xl text-[#eac290] mb-6 uppercase tracking-wider" style="font-family:'Noto Serif',serif;">{title}</h2><p class="max-w-2xl text-xl leading-relaxed text-[#d2c4b7] md:text-2xl" style="font-family:'Newsreader',serif;">{text}</p></div></div>)}</section><section class="py-48 text-center px-6 border-t border-[#4e453b]"><h2 class="mb-12 text-4xl text-white md:text-7xl" style="font-family:'Noto Serif',serif;">Ready for a different kind of introduction?</h2><p class="mx-auto mb-16 max-w-2xl text-xl text-[#d2c4b7] md:text-2xl" style="font-family:'Newsreader',serif;">We accept a limited number of new members each quarter to maintain the integrity of our service.</p><a href="/contact" class="inline-block bg-[#cda777] px-8 py-6 text-sm uppercase tracking-[0.18em] text-[#573c15] transition-colors duration-500 hover:bg-[#eac290] md:px-12 md:tracking-[0.3em]" style="font-family:'Newsreader',serif;">Begin the Dialogue</a></section></main></Layout>
