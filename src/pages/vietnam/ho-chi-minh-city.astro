---
import RegionPage from '~/components/RegionPage.astro';
const metadata = { title: "Private Matchmaking in Ho Chi Minh City | The Matchmaking Bureau", description: "Private matchmaking in Ho Chi Minh City for discerning Vietnamese professionals. HCMC's most accomplished singles served with absolute discretion." };
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://matchmakingbureau.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Vietnam",
      "item": "https://matchmakingbureau.com/vietnam"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Ho Chi Minh City",
      "item": "https://matchmakingbureau.com/vietnam/ho-chi-minh-city"
    }
  ]
};
const links = [{ text: "Vietnam", href: "/vietnam" }];
---
<RegionPage metadata={metadata} eyebrow="Private Matchmaking" hero="Ho Chi Minh City Bureau" body="Ho Chi Minh City is Vietnam's commercial capital - a city of extraordinary energy where entrepreneurs, professionals and innovators build careers of genuine significance. The Matchmaking Bureau brings private, curated introductions to HCMC's most accomplished and discerning individuals." image="/assets/images/cities/ho-chi-minh-city.jpg" links={links} schema={schema} />
