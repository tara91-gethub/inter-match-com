---
import RegionPage from '~/components/RegionPage.astro';
const metadata = { title: "Private Matchmaking in Vietnam | The Matchmaking Bureau", description: "Private matchmaking in Vietnam for discerning professionals. Serving Ho Chi Minh City with absolute discretion." };
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://matchmakingbureau.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Vietnam",
      "item": "https://matchmakingbureau.com/vietnam"
    }
  ]
};
const cards = [{"title":"Ho Chi Minh City","href":"/vietnam/ho-chi-minh-city","image":"/assets/images/cities/ho-chi-minh-city.jpg"}];
---
<RegionPage metadata={metadata} eyebrow="Private Matchmaking" hero="Vietnam Bureau" body="Vietnam is Southeast Asia's fastest rising economy - a country where a new generation of entrepreneurs, professionals and innovators are redefining what success looks like. The Matchmaking Bureau serves Vietnam's most accomplished individuals with private, curated introductions." image="/assets/images/countries/vietnam.jpg" cards={cards} links={[]} schema={schema} />
