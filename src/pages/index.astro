---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/JsonLd.astro';
import philippinesImg from '~/assets/images/countries/philippines.jpg';
import thailandImg from '~/assets/images/countries/thailand.jpg';
import indonesiaImg from '~/assets/images/countries/indonesia.jpg';
import malaysiaImg from '~/assets/images/countries/malaysia.jpg';
import singaporeImg from '~/assets/images/countries/singapore.jpg';
import vietnamImg from '~/assets/images/countries/vietnam.jpg';
import privateInteriorHeroImg from '~/assets/images/private-interior-hero.jpg';
import watchMovementDetailImg from '~/assets/images/watch-movement-detail.jpg';
const metadata = {
  title: 'Private Matchmaking in Southeast Asia',
  description: 'Private matchmaking across Southeast Asia for discerning professionals in the Philippines, Thailand, Indonesia, Malaysia, Singapore and Vietnam.',
  openGraph: { images: [{ url: '~/assets/images/og-default-international.jpg', width: 1200, height: 630 }] },
};
const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "The Matchmaking Bureau",
  "url": "https://matchmakingbureau.com",
  "logo": "https://matchmakingbureau.com/favicon.svg",
  "description": "Private matchmaking agency serving Southeast Asia - Philippines, Thailand, Indonesia, Malaysia, Singapore and Vietnam.",
  "areaServed": [
    "Philippines",
    "Thailand",
    "Indonesia",
    "Malaysia",
    "Singapore",
    "Vietnam"
  ],
  "serviceType": "Private Matchmaking Agency",
  "sameAs": []
};
const countries = [
  ['Philippines','/philippines',philippinesImg,'Manila and Cebu'],
  ['Thailand','/thailand',thailandImg,'Bangkok'],
  ['Indonesia','/indonesia',indonesiaImg,'Jakarta'],
  ['Malaysia','/malaysia',malaysiaImg,'Kuala Lumpur'],
  ['Singapore','/singapore',singaporeImg,'Singapore'],
  ['Vietnam','/vietnam',vietnamImg,'Ho Chi Minh City'],
];
---
<Layout metadata={metadata}>
  <JsonLd data={schema} />
  <main transition:animate="fade">
    <header class="relative w-full min-h-screen flex items-center overflow-hidden bg-[#0e1322] px-6 py-32 md:px-12">
      <div class="absolute inset-y-0 right-0 hidden w-1/2 lg:block"><Image class="h-full w-full object-cover grayscale opacity-40" alt="Private Southeast Asia interior" src={privateInteriorHeroImg} /><div class="absolute inset-0 bg-gradient-to-r from-[#0e1322] via-[#0e1322]/45 to-transparent"></div></div>
      <div class="relative z-10 max-w-7xl mx-auto w-full"><div class="max-w-3xl"><p class="mb-6 text-xs uppercase tracking-[0.3em] text-[#eac290]" style="font-family:'Newsreader',serif;">The Matchmaking Bureau</p><h1 class="mb-8 text-4xl leading-tight text-white sm:text-5xl md:text-7xl lg:text-8xl" style="font-family:'Noto Serif',serif;">The Fine Art of <span class="italic text-[#eac290]">Human Connection</span></h1><div class="mb-10 h-px w-24 bg-[#eac290]"></div><p class="mb-12 max-w-2xl text-lg leading-relaxed text-[#d2c4b7] md:text-2xl" style="font-family:'Newsreader',serif;">Exclusively serving Southeast Asia's most discerning individuals. We are not an app; we are an architectural approach to love.</p><div class="flex flex-col gap-5 sm:flex-row"><a href="/contact" class="inline-block bg-[#cda777] px-8 py-5 text-center text-xs font-bold uppercase tracking-[0.16em] text-[#573c15] transition-colors hover:bg-[#eac290] md:px-10 md:tracking-[0.25em]" style="font-family:'Noto Serif',serif;">Begin Your Application</a><a href="/about" class="inline-block border border-[#9b8f82] px-8 py-5 text-center text-xs font-bold uppercase tracking-[0.16em] text-[#eac290] transition-colors hover:bg-[#eac290]/10 md:px-10 md:tracking-[0.25em]" style="font-family:'Noto Serif',serif;">The Philosophy</a></div></div></div>
    </header>
    <section class="bg-[#0e1322] px-6 py-24 md:px-12 md:py-32"><div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-16 items-center"><div class="md:col-span-5 relative"><div class="border border-[#4e453b] p-2"><Image class="h-[420px] w-full object-cover md:h-[600px]" alt="Private introduction detail" src={watchMovementDetailImg}/></div></div><div class="md:col-span-7 md:pl-12"><p class="tracking-[0.25em] uppercase text-[#eac290] mb-6 text-sm" style="font-family:'Newsreader',serif;">The Private Atelier</p><h2 class="mb-8 text-3xl leading-tight text-white md:text-5xl" style="font-family:'Noto Serif',serif;">Precision in <br/>Human Connection.</h2><div class="space-y-6 text-lg text-[#d2c4b7] leading-relaxed max-w-xl" style="font-family:'Newsreader',serif;"><p>The Bureau is a private enclave for accomplished professionals across Southeast Asia who value discretion, substance and genuine compatibility.</p><p>Serving the Philippines, Thailand, Indonesia, Malaysia, Singapore and Vietnam, our approach is curated, selective and deeply human.</p></div></div></div></section>
    <section class="bg-[#161b2b] px-6 py-24 md:px-12 md:py-32"><div class="max-w-7xl mx-auto"><div class="mb-16 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end"><div><p class="tracking-[0.25em] uppercase text-[#eac290] mb-4 text-sm" style="font-family:'Newsreader',serif;">Countries</p><h2 class="text-3xl text-white md:text-4xl" style="font-family:'Noto Serif',serif;">The Southeast Asia Bureau</h2></div></div><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1">{countries.map(([name, href, image, label]) => <a href={href} class="relative group aspect-[3/4] overflow-hidden bg-[#25293a]"><Image class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-60" alt={name} src={image}/><div class="absolute inset-0 flex flex-col justify-end p-8"><h3 class="text-2xl text-[#eac290] tracking-widest uppercase mb-2" style="font-family:'Noto Serif',serif;">{name}</h3><p class="text-xs tracking-[0.2em] text-[#d2c4b7] uppercase opacity-0 group-hover:opacity-100 transition-opacity" style="font-family:'Newsreader',serif;">{label}</p></div></a>)}</div></div></section>
    <section class="bg-[#0e1322] px-6 py-24 md:px-12 md:py-32"><div class="max-w-5xl mx-auto"><div class="text-center mb-24"><p class="tracking-[0.25em] uppercase text-[#eac290] mb-4 text-sm" style="font-family:'Newsreader',serif;">Methodology</p><h2 class="text-3xl text-white md:text-4xl" style="font-family:'Noto Serif',serif;">The Protocol</h2></div><div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-[#4e453b]"><div class="border-b border-[#4e453b] p-8 transition-colors hover:bg-[#161b2b] md:border-b-0 md:border-r md:p-12"><p class="text-xs tracking-[0.2em] text-[#eac290] mb-4 uppercase" style="font-family:'Newsreader',serif;">Phase 01</p><h3 class="text-2xl text-white mb-6" style="font-family:'Noto Serif',serif;">Intake</h3><p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">A private assessment of values, lifestyle, intent and professional context.</p></div><div class="border-b border-[#4e453b] p-8 transition-colors hover:bg-[#161b2b] md:border-b-0 md:border-r md:p-12"><p class="text-xs tracking-[0.2em] text-[#eac290] mb-4 uppercase" style="font-family:'Newsreader',serif;">Phase 02</p><h3 class="text-2xl text-white mb-6" style="font-family:'Noto Serif',serif;">Curation</h3><p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">A carefully reviewed search across trusted regional circles.</p></div><div class="p-8 transition-colors hover:bg-[#161b2b] md:p-12"><p class="text-xs tracking-[0.2em] text-[#eac290] mb-4 uppercase" style="font-family:'Newsreader',serif;">Phase 03</p><h3 class="text-2xl text-white mb-6" style="font-family:'Noto Serif',serif;">Introduction</h3><p class="text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">A singular, high-probability introduction managed with discretion.</p></div></div></div></section>
    <section class="bg-[#0e1322] px-6 py-24 md:px-12 md:py-32"><div class="max-w-4xl mx-auto text-center border border-[#eac290] p-2"><div class="border border-[#eac290] px-6 py-16 md:px-12 md:py-24"><h2 class="text-4xl md:text-5xl text-white mb-8" style="font-family:'Noto Serif',serif;">Begin the Dialogue</h2><p class="text-xl text-[#d2c4b7] mb-12 max-w-lg mx-auto" style="font-family:'Newsreader',serif;">Membership is by application only. Start with a confidential inquiry.</p><a href="/contact" class="inline-block bg-[#cda777] text-[#573c15] px-12 py-5 tracking-[0.25em] uppercase text-sm hover:bg-[#eac290] transition-colors" style="font-family:'Noto Serif',serif;">Apply Now</a></div></div></section>
  </main>
</Layout>
