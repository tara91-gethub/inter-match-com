---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Membership',
  description: 'The Match Bureau membership tiers — The Private Circle, The Bureau Select, and The Founding Member. Private matchmaking for New Zealand\'s most discerning individuals.',
};
---

<Layout metadata={metadata}>
  <main transition:animate="fade">

    <section class="relative h-[819px] flex flex-col justify-center items-center text-center px-6 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-40">
        <img class="w-full h-full object-cover grayscale" alt="Private members club interior" src="https://lh3.googleusercontent.com/aida-public/AB6AXuATslzuf8O6EEVosSxgJ1casjTpe6GubWqQNXXngpdF1kg2Gn96iH_1nR9poj2bvwX_ElyfklrwCpGYopSX6ANEWg9zjD6HkFV2qOR526-7YKOYIOVV1DL1H9r6uz3J8EoZL9i1VXXabMCTmQTemO0oiADWR9-J_H2OmvVIPSrNhSRA_nnO6lUWCPfm4ANf_EGYcvJnExgCdh2rqkaVjbMIkpm8SBJTsObFdBj1rIp33GkdhCmQF7JquuPUfN1hJCuhx_q8WmCmB4FJ" />
      </div>
      <div class="relative z-10 max-w-4xl">
        <h1 class="text-[5rem] md:text-[8rem] leading-none text-[#eac290] mb-8 tracking-tighter" style="font-family:'Noto Serif',serif;">Membership</h1>
        <p class="text-xl md:text-2xl text-[#d2c4b7] max-w-2xl mx-auto italic leading-relaxed" style="font-family:'Newsreader',serif;">
          A curated entry into New Zealand's most exclusive private bureau. Entry is by selective inquiry only.
        </p>
        <div class="mt-12">
          <div class="w-px h-24 bg-[#eac290] mx-auto"></div>
        </div>
      </div>
    </section>

    <section class="py-32 px-12 bg-[#0e1322]">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-[#4e453b]">
          <div class="p-12 border-b md:border-b-0 md:border-r border-[#4e453b] flex flex-col justify-between hover:bg-[#161b2b] transition-colors duration-500">
            <div>
              <h2 class="uppercase tracking-[0.25em] text-[#eac290] mb-12 text-xs" style="font-family:'Newsreader',serif;">Tier 01</h2>
              <h3 class="text-4xl mb-8 text-white" style="font-family:'Noto Serif',serif;">The Private Circle</h3>
              <ul class="space-y-6 mb-16">
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Access to our silent database</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Quarterly newsletter</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Basic vetting</span>
                </li>
              </ul>
            </div>
            <a href="/contact" class="block w-full border border-[#9b8f82] text-[#eac290] text-center uppercase tracking-[0.2em] py-5 hover:bg-[#eac290] hover:text-[#442b06] transition-all duration-300 text-xs" style="font-family:'Newsreader',serif;">INQUIRE</a>
          </div>
          <div class="p-12 border-b md:border-b-0 md:border-r border-[#4e453b] flex flex-col justify-between bg-[#161b2b]">
            <div>
              <h2 class="uppercase tracking-[0.25em] text-[#eac290] mb-12 text-xs" style="font-family:'Newsreader',serif;">Tier 02</h2>
              <h3 class="text-4xl mb-8 text-white" style="font-family:'Noto Serif',serif;">The Bureau Select</h3>
              <ul class="space-y-6 mb-16">
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Active headhunting</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Dedicated matchmaker</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Preliminary vetting</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Bi-monthly introductions</span>
                </li>
              </ul>
            </div>
            <a href="/contact" class="block w-full bg-[#cda777] text-[#573c15] text-center uppercase tracking-[0.2em] py-5 hover:bg-[#eac290] transition-all duration-300 text-xs" style="font-family:'Newsreader',serif;">APPLY NOW</a>
          </div>
          <div class="p-12 flex flex-col justify-between hover:bg-[#161b2b] transition-colors duration-500">
            <div>
              <h2 class="uppercase tracking-[0.25em] text-[#eac290] mb-12 text-xs" style="font-family:'Newsreader',serif;">Tier 03</h2>
              <h3 class="text-4xl mb-8 text-white" style="font-family:'Noto Serif',serif;">The Founding Member</h3>
              <ul class="space-y-6 mb-16">
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Global search</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Private concierge</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Lifetime priority</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">24/7 advisory</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-[#eac290] text-sm mt-1">✦</span>
                  <span class="text-lg text-[#d2c4b7]" style="font-family:'Newsreader',serif;">Unlimited introductions</span>
                </li>
              </ul>
            </div>
            <a href="/contact" class="block w-full border border-[#9b8f82] text-[#eac290] text-center uppercase tracking-[0.2em] py-5 hover:bg-[#eac290] hover:text-[#442b06] transition-all duration-300 text-xs" style="font-family:'Newsreader',serif;">INQUIRE</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-32 px-12 bg-[#161b2b]">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
          <div class="max-w-2xl">
            <h2 class="uppercase tracking-[0.25em] text-[#eac290] mb-6 text-xs" style="font-family:'Newsreader',serif;">The Foundations</h2>
            <h3 class="text-6xl leading-tight text-white" style="font-family:'Noto Serif',serif;">The Pillars of Membership</h3>
          </div>
          <p class="text-xl text-[#d2c4b7] max-w-sm italic" style="font-family:'Newsreader',serif;">
            Built upon a legacy of trust and absolute structural integrity.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-[#4e453b] border border-[#4e453b]">
          <div class="bg-[#0e1322] p-10 flex flex-col gap-8 hover:bg-[#25293a] transition-all duration-500">
            <div class="w-12 h-px bg-[#eac290]"></div>
            <h4 class="text-2xl uppercase tracking-widest text-white" style="font-family:'Noto Serif',serif;">Absolute Discretion</h4>
            <p class="text-lg text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">A guarantee of total anonymity for our members. Your identity and search remain strictly confidential within our closed-loop system.</p>
          </div>
          <div class="bg-[#0e1322] p-10 flex flex-col gap-8 hover:bg-[#25293a] transition-all duration-500">
            <div class="w-12 h-px bg-[#eac290]"></div>
            <h4 class="text-2xl uppercase tracking-widest text-white" style="font-family:'Noto Serif',serif;">Concierge Service</h4>
            <p class="text-lg text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">From venue selection to travel logistics, our team handles every detail of the encounter, ensuring seamless, premium experiences.</p>
          </div>
          <div class="bg-[#0e1322] p-10 flex flex-col gap-8 hover:bg-[#25293a] transition-all duration-500">
            <div class="w-12 h-px bg-[#eac290]"></div>
            <h4 class="text-2xl uppercase tracking-widest text-white" style="font-family:'Noto Serif',serif;">Bespoke Introductions</h4>
            <p class="text-lg text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">We do not use algorithms. Every connection is hand-selected based on shared values, intellectual resonance, and aesthetic compatibility.</p>
          </div>
          <div class="bg-[#0e1322] p-10 flex flex-col gap-8 hover:bg-[#25293a] transition-all duration-500">
            <div class="w-12 h-px bg-[#eac290]"></div>
            <h4 class="text-2xl uppercase tracking-widest text-white" style="font-family:'Noto Serif',serif;">Relationship Coaching</h4>
            <p class="text-lg text-[#d2c4b7] leading-relaxed" style="font-family:'Newsreader',serif;">Strategic advisory for the modern romantic landscape. Expert guidance to ensure long-term alignment and success.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-48 px-12 relative overflow-hidden bg-[#090e1c]">
      <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
        <img class="w-full h-full object-cover" alt="Antique brass key on dark navy silk" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC1OkhPVElB32yfUx75Gzsoqoz8n8XZwzMx83zEhZuZ2WZE84dibKjD765R2uFeDCKxTrs2oAlkoA6ohftE9GJALlX6KrAnYLfQxrsw1nk5PcSuaiTlUaG8Se8WilFhBatBl1yV5Zp-sZyRIfSBItkEJlDkCfEsWmcYAdryuJzEvfknpo75dGj0NOJLHbDST4kJfVGhkgOwc6LPXYlXt35DB-jlHudGJ00dgeE7ipdqYJFYyzA3myAf5wVkuWW8vb7Cg36FGPEg5BqI" />
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-6xl md:text-8xl mb-12 text-white" style="font-family:'Noto Serif',serif;">Begin the Dialogue</h2>
        <p class="text-xl md:text-2xl text-[#d2c4b7] mb-16 italic max-w-2xl mx-auto" style="font-family:'Newsreader',serif;">
          Your journey into the bureau begins with a single conversation. We invite you to initiate the process.
        </p>
        <div class="flex flex-col md:flex-row gap-6 justify-center items-center">
          <a href="/contact" class="inline-block px-16 py-6 bg-[#cda777] text-[#573c15] uppercase tracking-[0.3em] hover:bg-[#eac290] transition-all duration-500 text-sm" style="font-family:'Newsreader',serif;">APPLY NOW</a>
          <a href="/process" class="inline-block px-16 py-6 border border-[#9b8f82] text-[#eac290] uppercase tracking-[0.3em] hover:bg-[#cda777]/10 transition-all duration-500 text-sm" style="font-family:'Newsreader',serif;">VIEW PROCESS</a>
        </div>
      </div>
    </section>

  </main>
</Layout>
